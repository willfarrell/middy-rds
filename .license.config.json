{
	"license": ".license.template",
	"licenseFormats": {
		"js|mjs|ts": {
			"eachLine": {
				"prepend": "// "
			}
		}
	},
	"ignoreFile": ".gitignore",
	"ignore": [
		".github/**/*",
		".husky/**/*",
		"bin/**/*",
		"certificates/**/*",
		"fixtures/*",
		"commitlint.config.cjs",
		"LICENSE",
		".license.template",
		"**/.gitignore",
		"**/*.fuzz.js",
		"**/*.perf.js",
		"**/*.test.js",
		"**/*.cjs",
		"**/*.md",
		"**/*.yml",
		"**/.DS_Store"
	]
}
