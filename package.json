{
	"name": "middy-rds",
	"version": "6.0.0",
	"description": "Simple RDS manager for the middy framework",
	"workspaces": [
		".github"
	],
	"type": "module",
	"engines": {
		"node": ">=24"
	},
	"engineStrict": true,
	"publishConfig": {
		"access": "public"
	},
	"main": "./index.mjs",
	"exports": {
		".": {
			"import": {
				"default": "./index.mjs"
			}
		},
